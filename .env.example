# Base
NODE_ENV=development
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Mode — true pour les deployements self-hosted (desactive billing, trial, limites de pages)
NUXT_PUBLIC_SELF_HOSTED=true

# Database
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/seogard?retryWrites=true&w=majority

# Tests E2E (Playwright) — base de données isolée, droppée à chaque run
E2E_DATABASE_URL=mongodb://user:password@host:27017/seogard-e2e?authSource=admin

# Auth — NUXT_JWT_SECRET doit faire 64+ caracteres en prod
NUXT_JWT_SECRET=change-me-in-production

# Stockage objet (Cloudflare R2 / S3 / MinIO) — rapports figés .md/.pdf + backups DB.
# Si non configuré : les rapports par crawl ne sont pas générés (feature off).
# - SaaS : pointer sur Cloudflare R2 (endpoint R2, region=auto).
# - Self-hosted (docker-compose.self-hosted.yml) : MinIO est fourni et câblé automatiquement,
#   il suffit de changer MINIO_ROOT_PASSWORD ci-dessous (les STORAGE_S3_* sont dérivés).
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=seogard-reports
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Self-hosted uniquement : identifiants du MinIO embarqué (À CHANGER).
MINIO_ROOT_USER=seogard
MINIO_ROOT_PASSWORD=changeme-minio

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_METERED=
# event_name du Billing Meter lié au prix metered (dashboard Stripe > Billing > Meters).
# Requis pour reporter la consommation de pages — sinon l'usage n'est PAS facturé.
STRIPE_METER_EVENT_NAME=

# Pricing — prix par page crawlée (défaut: 0.01 EUR)
NUXT_PUBLIC_PRICE_PER_PAGE=0.01

# Logs (prod)
BETTERSTACK_TOKEN=

# Analytics (prod only)
NUXT_PUBLIC_UMAMI_URL=
NUXT_PUBLIC_UMAMI_ID=

# Notifications (prod)
RESEND_API_KEY=
FROM_EMAIL=alerts@seogard.io

# OAuth (optionnel — laissez vide pour désactiver un provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# IndexNow — instant search engine notification
INDEXNOW_KEY=
