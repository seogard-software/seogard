# Base
NODE_ENV=development
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Mode — true pour les deployements self-hosted (desactive billing, trial, limites de pages)
NUXT_PUBLIC_SELF_HOSTED=true

# Database
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/seogard?retryWrites=true&w=majority

# Auth — NUXT_JWT_SECRET doit faire 64+ caracteres en prod
NUXT_JWT_SECRET=change-me-in-production

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_METERED=

# Pricing — prix par page crawlée (défaut: 0.007 EUR)
NUXT_PUBLIC_PRICE_PER_PAGE=0.01

# Logs (prod)
BETTERSTACK_TOKEN=

# Analytics (prod only)
NUXT_PUBLIC_UMAMI_URL=
NUXT_PUBLIC_UMAMI_ID=

# Notifications (prod)
RESEND_API_KEY=
FROM_EMAIL=alerts@seogard.io

# OAuth (optionnel — laissez vide pour désactiver un provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# IndexNow — instant search engine notification
INDEXNOW_KEY=
